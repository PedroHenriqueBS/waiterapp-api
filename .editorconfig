# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true # remove todos os espaçoes em branco no final das linhas
insert_final_newline = true # adiciona uma nova linha no final do arquivo, caso não exista
